# systemd unit for awsobs agent on EC2 instances.
#   sudo cp awsobs /usr/local/bin/ && sudo cp awsobs-agent.service /etc/systemd/system/
#   sudo systemctl enable --now awsobs-agent
[Unit]
Description=awsobs agent (host metrics + log shipping)
After=network-online.target
Wants=network-online.target

[Service]
Environment=AWSOBS_SERVER_URL=http://YOUR_SERVER_IP:8080
Environment=AWSOBS_TOKEN=CHANGE_ME_SHARED_INGEST_TOKEN
ExecStart=/usr/local/bin/awsobs agent
Restart=always
RestartSec=5
# Needs read access to /proc and any log files you tail; root is simplest,
# or grant a dedicated user membership in the adm/systemd-journal groups.
User=root

[Install]
WantedBy=multi-user.target
